{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "antinarkologia",
  "compatibility_date": "2026-04-13",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "antinarkologia-production",
      "database_id": "placeholder-replace-after-cf-login"
    }
  ]
}
