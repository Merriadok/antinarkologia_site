# ============================================================
# АНТИНаркология — Production Environment Variables
# Скопировать в: /var/www/antinarkologia/.env.production
# НИКОГДА не коммитить в git!
# ============================================================

# JWT (сгенерировать: openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS

# Базовый URL
BASE_URL=https://antinarkologia.ru

# ЮKassa (получить в личном кабинете kassa.yandex.ru)
YUKASSA_SHOP_ID=REPLACE_WITH_SHOP_ID
YUKASSA_SECRET_KEY=REPLACE_WITH_SECRET_KEY

# Email
EMAIL_FROM=noreply@antinarkologia.ru
CONSULTANT_EMAIL=mandybura@antinarkologia.ru

# Telegram-бот @antinarkologia_bot
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_BOT_SECRET=REPLACE_WITH_RANDOM_SECRET

# Telegram ID консультанта (получить через @userinfobot)
CONSULTANT_TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
CONSULTANT_TELEGRAM_CHAT_ID=REPLACE_WITH_CONSULTANT_CHAT_ID

# VAPID (Web Push уведомления)
VAPID_PUBLIC_KEY=BCnn9D2UJTcSCPRrBpR4XNbfQrTEuxPz4EWh9J8H0LS5wODU8-48NLtXwmKKqTRoMZ619YhGnCLlUbLmve84gk4
VAPID_PRIVATE_KEY=REPLACE_WITH_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@antinarkologia.ru

# Яндекс TeleМост (получить после подключения Яндекс 360 API)
TELEMOST_API_KEY=
